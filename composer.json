{
    "name": "valksor/php-form-type-cloudflare-turnstile",
    "description": "Symfony Form type for Cloudflare Turnstile bot protection",
    "license": "BSD-3-Clause",
    "type": "library",
    "keywords": [
        "php",
        "symfony",
        "valksor"
    ],
    "homepage": "https://github.com/valksor/php-valksor",
    "require": {
        "php": ">=8.4",
        "symfony/dependency-injection": "*",
        "symfony/form": "*",
        "symfony/http-client": "*",
        "symfony/http-foundation": "*",
        "symfony/options-resolver": "*",
        "symfony/validator": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "psr/log": "^3.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": false,
    "autoload": {
        "psr-4": {
            "Valksor\\Component\\FormType\\CloudflareTurnstile\\": ""
        }
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.0.x-dev"
        }
    }
}
